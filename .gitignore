# Workspace build artifacts (shared across members)
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
build/

# Per-platform build dirs
**/build/
**/.dart_tool/

# IDE
.idea/
*.iml
.vscode/

# OS
.DS_Store
Thumbs.db

# Flutter/Dart generated
**/doc/api/
**/ios/Flutter/.last_build_id
generated_plugin_registrant.*
generated_plugins.cmake

# Windows-specific generated files (auto-regenerated by flutter pub get)
**/windows/flutter/generated_plugin_registrant.cc
**/windows/flutter/generated_plugin_registrant.h
**/windows/flutter/generated_plugins.cmake
**/windows/flutter/ephemeral/

# === Reaction Roulette specifics ===

# Downloaded model files (~480 MB total) — fetched by scripts/download_models.dart
# Do NOT commit these.
assets/models/
!assets/models/.gitkeep

# Bundled native binaries (ffmpeg, vcredist DLLs) — fetched by scripts/download_binaries.dart
# Do NOT commit these.
assets/bin/
!assets/bin/.gitkeep

# Local storage (dev mode default). User chooses a real location on first launch.
storage/
config.json

# ONNX validation report (regenerated by scripts/validate_onnx_models.dart)
scripts/validation_report.json

# Test images used during validation
scripts/test_data/

# OS-specific lock files
*.lock.db
*.tmp

# Stray windows/ at workspace root (leftover from before restructure — should not exist)
/windows/
